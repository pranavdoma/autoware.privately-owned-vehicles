# VisionPilot configuration template
#   cp config/vision_pilot.conf.example config/vision_pilot.conf

# ─── Input source ────────────────────────────────────────────────────────────
source.mode             = video
source.video_path       = /data/zod/videos/001400_camera_front_blur_10fps.mp4
source.video_realtime   = true
source.video_loop       = false

source.ros2_topic       = /camera/image
source.v4l2_device      = /dev/video0
source.v4l2_fps         = 10

# ─── ONNX models ───────────────────────────────────────────────────────────────

engine.provider     = cpu
engine.device_id    = 0
engine.cache_dir    = /tmp/visionpilot_trt_cache
engine.workspace_gb = 1.0

# Model precision fp32 or int8 for quantized models lowercase
model.precision    = fp32

pipeline.initial_inference_check = true

# ───────────────────────────────────────────────────────────────────────────────
speed_limit      = 16.666; # m/s
Lf               = 2.67    # Front axle to CoG (m). Wheelbase L = Lf + Lr